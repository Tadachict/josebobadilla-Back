{
  "name": "jose-bobadilla-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev":        "ts-node-dev --respawn --transpile-only src/index.ts",
    "build":      "tsc",
    "start":      "node dist/index.js",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:seed":    "ts-node src/db/seed.ts"
  },
  "dependencies": {
    "express":            "^4.18.3",
    "cors":               "^2.8.5",
    "mysql2":             "^3.9.1",
    "bcryptjs":           "^2.4.3",
    "jsonwebtoken":       "^9.0.2",
    "dotenv":             "^16.4.5",
    "helmet":             "^7.1.0",
    "express-rate-limit": "^7.2.0",
    "multer":             "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express":      "^4.17.21",
    "@types/cors":         "^2.8.17",
    "@types/bcryptjs":     "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer":       "^1.4.11",
    "@types/node":         "^20.11.16",
    "typescript":          "^5.3.3",
    "ts-node-dev":         "^2.0.0",
    "ts-node":             "^10.9.2"
  }
}
